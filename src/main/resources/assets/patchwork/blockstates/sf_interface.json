{
  "multipart": [
    {
      "when": {
        "facing": "down"
      },
      "apply": {
        "model": "patchwork:block/sf_interface"
      }
    },
    {
      "when": {
        "facing": "up"
      },
      "apply": {
        "model": "patchwork:block/sf_interface",
        "x": 180
      }
    },
    {
      "when": {
        "facing": "south"
      },
      "apply": {
        "model": "patchwork:block/sf_interface",
        "x": 90
      }
    },
    {
      "when": {
        "facing": "west"
      },
      "apply": {
        "model": "patchwork:block/sf_interface",
        "x": 90,
        "y": 90
      }
    },
    {
      "when": {
        "facing": "east"
      },
      "apply": {
        "model": "patchwork:block/sf_interface",
        "x": 90,
        "y": 270
      }
    },
    {
      "when": {
        "facing": "north"
      },
      "apply": {
        "model": "patchwork:block/sf_interface",
        "x": 90,
        "y": 180
      }
    },
    {
      "when": {
        "north": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part"
      }
    },
    {
      "when": {
        "south": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "y": 180
      }
    },
    {
      "when": {
        "east": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "y": 90
      }
    },
    {
      "when": {
        "west": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "y": 270
      }
    },
    {
      "when": {
        "up": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "x": 270
      }
    },
    {
      "when": {
        "down": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "x": 90
      }
    }
  ]
}