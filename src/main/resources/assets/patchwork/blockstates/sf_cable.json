{
  "multipart": [
    {
      "apply": {
        "model": "patchwork:block/sf_cable"
      }
    },
    {
      "when": {
        "north": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part"
      }
    },
    {
      "when": {
        "south": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "y": 180
      }
    },
    {
      "when": {
        "east": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "y": 90
      }
    },
    {
      "when": {
        "west": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "y": 270
      }
    },
    {
      "when": {
        "up": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "x": 270
      }
    },
    {
      "when": {
        "down": true
      },
      "apply": {
        "model": "patchwork:block/sf_cable_part",
        "x": 90
      }
    }
  ]
}